TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_USERNAME=your_twitch_username_here

# Optional: "tiktok" (default) or "youtube"
PLATFORM=youtube

# YouTube VOD lookup (required if PLATFORM=youtube)
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_HANDLE=your_channel_handle_here

# YouTube Shorts upload (from Google Cloud Console → OAuth 2.0 Client ID, Desktop app type)
YOUTUBE_CLIENT_ID=your_oauth_client_id_here
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret_here
